# OpenShelf Environment Configuration Example
# Copy this file to .env and fill in your details

# SMTP Settings
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password

# Email Settings
MAIL_FROM_ADDRESS=no-reply@openshelf.org
MAIL_FROM_NAME=OpenShelf
MAIL_REPLY_TO=support@openshelf.org
ADMIN_EMAIL=admin@openshelf.org

# Application Settings
APP_NAME=OpenShelf
APP_URL=http://localhost
DEBUG=false
