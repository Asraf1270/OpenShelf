# OpenShelf Environment Configuration Example
# Copy this file to .env and fill in your details

# SMTP Settings
SMTP_HOST=your_smtp_host_name
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password

# Email Settings
MAIL_FROM_ADDRESS=no-reply@duopenshelf.top
MAIL_FROM_NAME=OpenShelf
MAIL_REPLY_TO=support@duopenshelf.top
ADMIN_EMAIL=admin@duopenshelf.top

# Application Settings
APP_NAME=OpenShelf
APP_URL=https://duopenshelf.top
DEBUG=false

# Database Settings
DB_HOST=localhost
DB_NAME=openshelf_db
DB_USER=root
DB_PASS=
